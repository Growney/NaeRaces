# Copy this file to .env and set real values before running docker compose.
# .env is excluded from source control via .gitignore.

SQL_SA_PASSWORD=
KURRENTDB_PASSWORD=

# Docker Hub image registry
# DOCKER_HUB_USERNAME – your Docker Hub username or organisation
# IMAGE_TAG           – image tag to deploy (e.g. latest, v1.2.3, git SHA)
DOCKER_HUB_USERNAME=
IMAGE_TAG=latest

# Let's Encrypt / Namecheap DNS-01
# ACME_EMAIL        – e-mail address for the Let's Encrypt account
# NAMECHEAP_USERNAME – your Namecheap account username
# NAMECHEAP_API_KEY  – generated at https://ap.www.namecheap.com/settings/tools/apiaccess/
# NAMECHEAP_SOURCEIP – public IP of the server (must be whitelisted in Namecheap API settings)
ACME_EMAIL=
NAMECHEAP_USERNAME=
NAMECHEAP_API_KEY=
NAMECHEAP_SOURCEIP=
