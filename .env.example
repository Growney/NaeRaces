# Copy this file to .env and set real values before running docker compose.
# .env is excluded from source control via .gitignore.

SQL_SA_PASSWORD=
KURRENTDB_PASSWORD=

# Docker Hub image registry
# DOCKER_HUB_USERNAME – your Docker Hub username or organisation
# IMAGE_TAG           – image tag to deploy (e.g. latest, v1.2.3, git SHA)
DOCKER_HUB_USERNAME=
IMAGE_TAG=latest
