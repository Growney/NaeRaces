{
  "ConnectionStrings": {
    "NaeRacesQuery": "Server=localhost;Database=NaeRacesQuery; TrustServerCertificate=True; User Id=sa;Password=&Password1234;",
    "OpenIddict": "Server=localhost;Database=NaeRacesOpenIddict; TrustServerCertificate=True; User Id=sa;Password=&Password1234;",
    "KurrentDb": "kurrentdb://admin:changeit@localhost:2113?tls=false&tlsVerifyCert=false"
  },
  "OpenIddictClients": [
    {
      "ClientId": "naeraces-blazor-client",
      "ConsentType": "implicit",
      "DisplayName": "NaeRaces Blazor Client",
      "ClientType": "public",
      "PostLogoutRedirectUris": [
        "https://localhost:7229/authentication/logout-callback"
      ],
      "RedirectUris": [
        "https://localhost:7229/authentication/login-callback"
      ],
      "Permissions": [
        "ept:authorization",
        "ept:end_session",
        "ept:token",
        "gt:authorization_code",
        "gt:refresh_token",
        "rst:code",
        "scp:email",
        "scp:profile",
        "scp:roles"
      ],
      "Requirements": [
        "ft:pkce"
      ]
    }
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
