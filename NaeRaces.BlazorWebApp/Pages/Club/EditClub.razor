    // Pilot policy methods
    private async Task ToggleManagePolicyAsync(Guid policyId)
    {
        if (managingPolicyId == policyId)
        {
            managingPolicyId = null;
            policyStatements = [];
            requirementMessage = null;
        }
        else
        {
            managingPolicyId = policyId;
            selectedRequirementType = string.Empty;
            requirementMessage = null;
            await LoadPolicyStatementsAsync(policyId);
        }
    }

    private async Task LoadPolicyStatementsAsync(Guid policyId)
    {
        isPolicyStatementsLoading = true;
        try
        {
            policyStatements = await Http.GetFromJsonAsync<List<PilotPolicyStatementResponse>>($"api/pilotselectionpolicy/{policyId}/query/statements") ?? [];
        }
        catch
        {
            policyStatements = [];
        }
        finally
        {
            isPolicyStatementsLoading = false;
        }
    }

    private async Task CreatePolicyAsync()
    {
        isCreatingPolicy = true;
        policyMessage = null;
        try
        {
            var request = new CreatePilotSelectionPolicyRequest
            {
                PilotSelectionPolicyId = Guid.NewGuid(),
                ClubId = ClubId,
                Name = newPolicyModel.Name,
                Description = newPolicyModel.Description
            };
            var response = await Http.PostAsJsonAsync("api/pilotselectionpolicy", request);
            policySuccess = response.IsSuccessStatusCode;
            policyMessage = response.IsSuccessStatusCode ? "Policy created." : "Failed to create policy.";
            if (response.IsSuccessStatusCode)
            {
                newPolicyModel = new NewPolicyFormModel();
                await RefreshPoliciesAsync();
            }
        }
        catch
        {
            policySuccess = false;
            policyMessage = "An error occurred.";
        }
        finally
        {
            isCreatingPolicy = false;
        }
    }

    private async Task AddRequirementAsync(Guid policyId)
    {
        if (string.IsNullOrEmpty(selectedRequirementType)) return;
        isAddingRequirement = true;
        requirementMessage = null;
        try
        {
            HttpResponseMessage response = selectedRequirementType switch
            {
                "MinimumAge" => await Http.PostAsJsonAsync($"api/pilotselectionpolicy/{policyId}/requirement/minimumage", minAgeModel),
                "MaximumAge" => await Http.PostAsJsonAsync($"api/pilotselectionpolicy/{policyId}/requirement/maximumage", maxAgeModel),
                "InsuranceProvider" => await Http.PostAsJsonAsync($"api/pilotselectionpolicy/{policyId}/requirement/insuranceprovider", insuranceModel),
                "GovernmentDocument" => await Http.PostAsJsonAsync($"api/pilotselectionpolicy/{policyId}/requirement/governmentdocument", govDocModel),
                "Club" => await Http.PostAsJsonAsync($"api/pilotselectionpolicy/{policyId}/requirement/club", new NaeRaces.WebAPI.Shared.PilotSelectionPolicy.AddClubRequirementRequest { ClubId = Guid.TryParse(clubRequirementClubId, out var cid) ? cid : Guid.Empty }),
                "ClubMembershipLevel" => await Http.PostAsJsonAsync($"api/pilotselectionpolicy/{policyId}/requirement/clubmembershiplevel", new AddClubMembershipLevelRequirementRequest { ClubId = Guid.TryParse(clubLevelClubId, out var clid) ? clid : Guid.Empty, MembershipLevel = clubLevelModel.MembershipLevel }),
                "Composite" => await Http.PostAsJsonAsync($"api/pilotselectionpolicy/{policyId}/statement", compositeModel),
                _ => throw new InvalidOperationException()
            };
            requirementSuccess = response.IsSuccessStatusCode;
            requirementMessage = response.IsSuccessStatusCode ? "Statement added." : "Failed to add statement.";
            if (response.IsSuccessStatusCode)
            {
                ResetRequirementModels();
                await LoadPolicyStatementsAsync(policyId);
            }
        }
        catch
        {
            requirementSuccess = false;
            requirementMessage = "An error occurred.";
        }
        finally
        {
            isAddingRequirement = false;
        }
    }

    private void ResetRequirementModels()
    {
        minAgeModel = new() { ValidationPolicy = "ANY" };
        maxAgeModel = new() { ValidationPolicy = "ANY" };
        insuranceModel = new() { ValidationPolicy = "ANY" };
        govDocModel = new() { ValidationPolicy = "ANY" };
        clubRequirementClubId = string.Empty;
        clubLevelClubId = string.Empty;
        clubLevelModel = new();
        compositeModel = new() { Operand = "AND" };
    }

    private async Task RemoveStatementAsync(Guid policyId, int statementId)
    {
        var response = await Http.DeleteAsync($"api/pilotselectionpolicy/{policyId}/statement/{statementId}");
        if (response.IsSuccessStatusCode)
        {
            await LoadPolicyStatementsAsync(policyId);
            await RefreshPoliciesAsync();
        }
    }

    private async Task SetRootStatementAsync(Guid policyId, int statementId)
    {
        var response = await Http.PutAsJsonAsync($"api/pilotselectionpolicy/{policyId}/rootstatement", new SetRootStatementRequest { RootPolicyStatementId = statementId });
        if (response.IsSuccessStatusCode)
        {
            await RefreshPoliciesAsync();
        }
    }

    private async Task RefreshPoliciesAsync()
    {
        var result = await Http.GetFromJsonAsync<List<PilotSelectionPolicyResponse>>($"api/club/{ClubId}/query/pilotpolicies");
        policies = result ?? [];
    }

    private static string GetStatementSummary(PilotPolicyStatementResponse stmt) => stmt.StatementType switch
    {
        "MinimumAge" => $"Min age \u2265 {stmt.MinimumAge} ({stmt.ValidationPolicy})",
        "MaximumAge" => $"Max age \u2264 {stmt.MaximumAge} ({stmt.ValidationPolicy})",
        "InsuranceProvider" => $"Insurance: {stmt.InsuranceProvider} ({stmt.ValidationPolicy})",
        "GovernmentDocument" => $"Gov doc: {stmt.GovernmentDocument} ({stmt.ValidationPolicy})",
        "ClubMembership" => $"Club member: {stmt.RequiredClubId}",
        "ClubMembershipLevel" => $"Club {stmt.RequiredClubId} / level {stmt.RequiredMembershipLevelId}",
        "Composite" => $"{(stmt.IsWithinBrackets == true ? "(" : "")}#{stmt.LeftHandStatementId} {stmt.Operand} #{stmt.RightHandStatementId}{(stmt.IsWithinBrackets == true ? ")" : "")}",
        _ => stmt.StatementType
    };

