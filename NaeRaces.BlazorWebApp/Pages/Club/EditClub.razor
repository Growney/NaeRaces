@page "/club/edit/{ClubId:guid}"
@attribute [Authorize]
@using NaeRaces.WebAPI.Shared.Club
@using NaeRaces.WebAPI.Shared.PilotSelectionPolicy
@using System.ComponentModel.DataAnnotations
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Edit Club</PageTitle>

@if (isLoading)
{
    <div class="d-flex align-items-center">
        <span class="spinner-border me-2" role="status" aria-hidden="true"></span>
        <em>Loading club...</em>
    </div>
}
else if (overview == null)
{
    <div class="alert alert-warning">Club not found.</div>
    <a href="/" class="btn btn-secondary">Back to Home</a>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-0">@overview.Name</h1>
            <span class="text-muted">@overview.Code &bull; @overview.MemberCount members</span>
        </div>
        <a href="/" class="btn btn-outline-secondary">Back to Home</a>
    </div>

    <!-- Basic Details -->
    <div class="card mb-3">
        <div class="card-header fw-bold">Basic Details</div>
        <div class="card-body">
            <EditForm Model="detailsModel" OnValidSubmit="SaveDetailsAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Code</label>
                        <InputText @bind-Value="detailsModel.Code" class="form-control" />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Name</label>
                        <InputText @bind-Value="detailsModel.Name" class="form-control" />
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(detailsMessage))
                {
                    <div class="alert @(detailsSuccess ? "alert-success" : "alert-danger") mt-2 mb-0 py-2">@detailsMessage</div>
                }
                <button type="submit" class="btn btn-primary mt-3" disabled="@isSavingDetails">
                    @if (isSavingDetails)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    Save Details
                </button>
            </EditForm>
        </div>
    </div>

    <!-- Description -->
    <div class="card mb-3">
        <div class="card-header fw-bold">Description</div>
        <div class="card-body">
            <EditForm Model="descriptionModel" OnValidSubmit="SaveDescriptionAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <InputTextArea @bind-Value="descriptionModel.Description" class="form-control" rows="4" />
                </div>
                @if (!string.IsNullOrEmpty(descriptionMessage))
                {
                    <div class="alert @(descriptionSuccess ? "alert-success" : "alert-danger") mb-2 py-2">@descriptionMessage</div>
                }
                <button type="submit" class="btn btn-primary" disabled="@isSavingDescription">
                    @if (isSavingDescription)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    Save Description
                </button>
            </EditForm>
        </div>
    </div>

    <!-- Contact Details -->
    <div class="card mb-3">
        <div class="card-header fw-bold">Contact Details</div>
        <div class="card-body">
            <EditForm Model="contactModel" OnValidSubmit="SaveContactAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Phone Number</label>
                        <InputText @bind-Value="contactModel.PhoneNumber" class="form-control" placeholder="+44 123 456 7890" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email Address</label>
                        <InputText @bind-Value="contactModel.EmailAddress" class="form-control" placeholder="club@example.com" />
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(contactMessage))
                {
                    <div class="alert @(contactSuccess ? "alert-success" : "alert-danger") mt-2 mb-0 py-2">@contactMessage</div>
                }
                <button type="submit" class="btn btn-primary mt-3" disabled="@isSavingContact">
                    @if (isSavingContact)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    Save Contact Details
                </button>
            </EditForm>
        </div>
    </div>

    <!-- Locations -->
    <div class="card mb-3">
        <div class="card-header fw-bold">Locations</div>
        <div class="card-body">
            @if (locations.Count == 0)
            {
                <p class="text-muted">No locations added yet.</p>
            }
            else
            {
                @foreach (var loc in locations)
                {
                    <div class="border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div>
                                <strong>@loc.Name</strong>
                                @if (loc.IsHomeLocation)
                                {
                                    <span class="badge bg-primary ms-2">Home</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(loc.Information))
                                {
                                    <br /><small class="text-muted">@loc.Information</small>
                                }
                                <br />
                                <small class="text-muted">
                                    @loc.AddressLine1@(loc.AddressLine2 != null ? ", " + loc.AddressLine2 : ""), @loc.City, @loc.Postcode, @loc.County
                                </small>
                            </div>
                            <div class="d-flex gap-2 flex-shrink-0">
                                @if (!loc.IsHomeLocation)
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => SetHomeLocationAsync(loc.LocationId)">
                                        Set as Home
                                    </button>
                                }
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleEditLocation(loc.LocationId)">
                                    @(editingLocationId == loc.LocationId ? "Cancel" : "Edit")
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLocationAsync(loc.LocationId)">
                                    Remove
                                </button>
                            </div>
                        </div>

                        @if (editingLocationId == loc.LocationId)
                        {
                            <hr />
                            <EditForm Model="locationEditModel" OnValidSubmit="SaveLocationAsync">
                                <DataAnnotationsValidator />
                                <ValidationSummary class="text-danger" />
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Name</label>
                                        <InputText @bind-Value="locationEditModel.Name" class="form-control" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Information</label>
                                        <InputTextArea @bind-Value="locationEditModel.Information" class="form-control" rows="2" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Address Line 1</label>
                                        <InputText @bind-Value="locationEditModel.AddressLine1" class="form-control" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Address Line 2</label>
                                        <InputText @bind-Value="locationEditModel.AddressLine2" class="form-control" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">City</label>
                                        <InputText @bind-Value="locationEditModel.City" class="form-control" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Postcode</label>
                                        <InputText @bind-Value="locationEditModel.Postcode" class="form-control" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">County</label>
                                        <InputText @bind-Value="locationEditModel.County" class="form-control" />
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(locationMessage))
                                {
                                    <div class="alert @(locationSuccess ? "alert-success" : "alert-danger") mt-2 mb-0 py-2">@locationMessage</div>
                                }
                                <button type="submit" class="btn btn-primary mt-3" disabled="@isSavingLocation">
                                    @if (isSavingLocation)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                    }
                                    Save Location
                                </button>
                            </EditForm>
                        }
                    </div>
                }
            }

            <hr />
            <h6>Add Location</h6>
            <EditForm Model="addLocationModel" OnValidSubmit="AddLocationAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <InputText @bind-Value="addLocationModel.LocationName" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Information <span class="text-danger">*</span></label>
                        <InputTextArea @bind-Value="addLocationModel.LocationInformation" class="form-control" rows="2" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Address Line 1 <span class="text-danger">*</span></label>
                        <InputText @bind-Value="addLocationModel.AddressLine1" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Address Line 2</label>
                        <InputText @bind-Value="addLocationModel.AddressLine2" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">City <span class="text-danger">*</span></label>
                        <InputText @bind-Value="addLocationModel.City" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Postcode <span class="text-danger">*</span></label>
                        <InputText @bind-Value="addLocationModel.Postcode" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">County <span class="text-danger">*</span></label>
                        <InputText @bind-Value="addLocationModel.County" class="form-control" />
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(addLocationMessage))
                {
                    <div class="alert @(addLocationSuccess ? "alert-success" : "alert-danger") mt-2 mb-0 py-2">@addLocationMessage</div>
                }
                <button type="submit" class="btn btn-success mt-3" disabled="@isAddingLocation">
                    @if (isAddingLocation)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    Add Location
                </button>
            </EditForm>
        </div>
    </div>

    <!-- Membership Levels -->
    <div class="card mb-4">
        <div class="card-header fw-bold">Membership Levels</div>
        <div class="card-body">
            @if (membershipLevels.Count == 0)
            {
                <p class="text-muted">No membership levels added yet.</p>
            }
            else
            {
                @foreach (var level in membershipLevels)
                {
                    <div class="border rounded p-3 mb-2">
                        <div class="d-flex justify-content-between align-items-center gap-2">
                            @if (editingMembershipLevelId == level.MembershipLevelId)
                            {
                                <div class="flex-grow-1">
                                    <input type="text" class="form-control form-control-sm" @bind="renameLevelModel.NewName" />
                                </div>
                                <div class="d-flex gap-2 flex-shrink-0">
                                    <button class="btn btn-sm btn-primary" @onclick="() => RenameLevelAsync(level.MembershipLevelId)" disabled="@isRenamingLevel">
                                        @if (isRenamingLevel)
                                        {
                                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                        }
                                        else
                                        {
                                            <text>Save</text>
                                        }
                                    </button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => editingMembershipLevelId = null">Cancel</button>
                                </div>
                            }
                            else
                            {
                                <strong>@level.Name</strong>
                                <div class="d-flex gap-2 flex-shrink-0">
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartRenameLevel(level.MembershipLevelId, level.Name)">Rename</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLevelAsync(level.MembershipLevelId)">Remove</button>
                                </div>
                            }
                        </div>
                    </div>
                }
            }

            @if (!string.IsNullOrEmpty(levelMessage))
            {
                <div class="alert @(levelSuccess ? "alert-success" : "alert-danger") py-2">@levelMessage</div>
            }

            <hr />
            <h6>Add Membership Level</h6>
            <EditForm Model="addLevelModel" OnValidSubmit="AddLevelAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                <div class="input-group">
                    <InputText @bind-Value="addLevelModel.Name" class="form-control" placeholder="Level name..." />
                    <button type="submit" class="btn btn-success" disabled="@isAddingLevel">
                        @if (isAddingLevel)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        Add Level
                    </button>
                </div>
            </EditForm>
        </div>
    </div>

    <!-- Pilot Selection Policies -->
    <div class="card mb-4">
        <div class="card-header fw-bold">Pilot Selection Policies</div>
        <div class="card-body">
            @if (policies.Count == 0)
            {
                <p class="text-muted">No pilot selection policies yet.</p>
            }
            else
            {
                @foreach (var policy in policies)
                {
                    <div class="border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <strong>@policy.Name</strong>
                                @if (!string.IsNullOrWhiteSpace(policy.Description))
                                {
                                    <br /><small class="text-muted">@policy.Description</small>
                                }
                            </div>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleManagePolicyAsync(policy.PolicyId)">
                                @(managingPolicyId == policy.PolicyId ? "Done" : "Manage")
                            </button>
                        </div>

                        @if (managingPolicyId == policy.PolicyId)
                        {
                            <hr />
                            <h6>Statements</h6>
                            @if (isPolicyStatementsLoading)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            }
                            else if (policyStatements.Count == 0)
                            {
                                <p class="text-muted">No statements added yet.</p>
                            }
                            else
                            {
                                @foreach (var stmt in policyStatements)
                                {
                                    <div class="d-flex justify-content-between align-items-center border rounded p-2 mb-2">
                                        <div>
                                            <strong>#@stmt.StatementId</strong>
                                            @if (policy.RootStatementId == stmt.StatementId)
                                            {
                                                <span class="badge bg-primary ms-1">Root</span>
                                            }
                                            <span class="ms-2 text-muted">@GetStatementSummary(stmt)</span>
                                        </div>
                                        <div class="d-flex gap-1">
                                            @if (policy.RootStatementId != stmt.StatementId)
                                            {
                                                <button class="btn btn-sm btn-outline-primary" @onclick="() => SetRootStatementAsync(policy.PolicyId, stmt.StatementId)">Set Root</button>
                                            }
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveStatementAsync(policy.PolicyId, stmt.StatementId)">Remove</button>
                                        </div>
                                    </div>
                                }
                            }

                            <hr />
                            <h6>Add Statement</h6>
                            <div class="mb-2">
                                <select class="form-select form-select-sm" @bind="selectedRequirementType">
                                    <option value="">Select type...</option>
                                    <option value="MinimumAge">Minimum Age</option>
                                    <option value="MaximumAge">Maximum Age</option>
                                    <option value="InsuranceProvider">Insurance Provider</option>
                                    <option value="GovernmentDocument">Government Document</option>
                                    <option value="Club">Club Membership</option>
                                    <option value="ClubMembershipLevel">Club Membership Level</option>
                                    <option value="Composite">Composite (AND/OR)</option>
                                </select>
                            </div>

                            @if (selectedRequirementType == "MinimumAge")
                            {
                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label">Minimum Age</label>
                                        <input type="number" class="form-control form-control-sm" @bind="minAgeModel.MinimumAge" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Validation Policy</label>
                                        <select class="form-select form-select-sm" @bind="minAgeModel.ValidationPolicy">
                                            @foreach (var vp in validationPolicyOptions)
                                            {
                                                <option value="@vp.Key">@vp.Value</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            }
                            else if (selectedRequirementType == "MaximumAge")
                            {
                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label">Maximum Age</label>
                                        <input type="number" class="form-control form-control-sm" @bind="maxAgeModel.MaximumAge" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Validation Policy</label>
                                        <select class="form-select form-select-sm" @bind="maxAgeModel.ValidationPolicy">
                                            @foreach (var vp in validationPolicyOptions)
                                            {
                                                <option value="@vp.Key">@vp.Value</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            }
                            else if (selectedRequirementType == "InsuranceProvider")
                            {
                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label">Insurance Provider</label>
                                        <input type="text" class="form-control form-control-sm" @bind="insuranceModel.InsuranceProvider" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Validation Policy</label>
                                        <select class="form-select form-select-sm" @bind="insuranceModel.ValidationPolicy">
                                            @foreach (var vp in validationPolicyOptions)
                                            {
                                                <option value="@vp.Key">@vp.Value</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            }
                            else if (selectedRequirementType == "GovernmentDocument")
                            {
                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label">Government Document</label>
                                        <input type="text" class="form-control form-control-sm" @bind="govDocModel.GovernmentDocument" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Validation Policy</label>
                                        <select class="form-select form-select-sm" @bind="govDocModel.ValidationPolicy">
                                            @foreach (var vp in validationPolicyOptions)
                                            {
                                                <option value="@vp.Key">@vp.Value</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            }
                            else if (selectedRequirementType == "Club")
                            {
                                <div class="row g-2 mb-2">
                                    <div class="col-md-6">
                                        <label class="form-label">Required Club ID</label>
                                        <input type="text" class="form-control form-control-sm" @bind="clubRequirementClubId" placeholder="GUID" />
                                    </div>
                                </div>
                            }
                            else if (selectedRequirementType == "ClubMembershipLevel")
                            {
                                <div class="row g-2 mb-2">
                                    <div class="col-md-4">
                                        <label class="form-label">Required Club ID</label>
                                        <input type="text" class="form-control form-control-sm" @bind="clubLevelClubId" placeholder="GUID" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Membership Level</label>
                                        <input type="number" class="form-control form-control-sm" @bind="clubLevelModel.MembershipLevel" />
                                    </div>
                                </div>
                            }
                            else if (selectedRequirementType == "Composite")
                            {
                                <div class="row g-2 mb-2">
                                    <div class="col-md-3">
                                        <label class="form-label">Left Statement #</label>
                                        <input type="number" class="form-control form-control-sm" @bind="compositeModel.LeftHandStatementId" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Operand</label>
                                        <select class="form-select form-select-sm" @bind="compositeModel.Operand">
                                            <option value="AND">AND</option>
                                            <option value="OR">OR</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Right Statement #</label>
                                        <input type="number" class="form-control form-control-sm" @bind="compositeModel.RightHandStatementId" />
                                    </div>
                                    <div class="col-md-3 d-flex align-items-end">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" @bind="compositeModel.IsWithinBrackets" id="bracketsCheck" />
                                            <label class="form-check-label" for="bracketsCheck">Brackets</label>
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(selectedRequirementType))
                            {
                                @if (!string.IsNullOrEmpty(requirementMessage))
                                {
                                    <div class="alert @(requirementSuccess ? "alert-success" : "alert-danger") py-1 mb-2">@requirementMessage</div>
                                }
                                <button class="btn btn-sm btn-primary" disabled="@isAddingRequirement" @onclick="() => AddRequirementAsync(policy.PolicyId)">
                                    @if (isAddingRequirement)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                    }
                                    Add Statement
                                </button>
                            }
                        }
                    </div>
                }
            }

            @if (!string.IsNullOrEmpty(policyMessage))
            {
                <div class="alert @(policySuccess ? "alert-success" : "alert-danger") py-2">@policyMessage</div>
            }

            <hr />
            <h6>Create New Policy</h6>
            <EditForm Model="newPolicyModel" OnValidSubmit="CreatePolicyAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <InputText @bind-Value="newPolicyModel.Name" class="form-control" />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Description <span class="text-danger">*</span></label>
                        <InputText @bind-Value="newPolicyModel.Description" class="form-control" />
                    </div>
                </div>
                <button type="submit" class="btn btn-success mt-3" disabled="@isCreatingPolicy">
                    @if (isCreatingPolicy)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    Create Policy
                </button>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ClubId { get; set; }

    private bool isLoading = true;
    private ClubOverviewResponse? overview;
    private List<ClubLocationResponse> locations = [];
    private List<ClubMembershipLevelResponse> membershipLevels = [];
    private List<PilotSelectionPolicyResponse> policies = [];

    private UpdateClubDetailsRequest detailsModel = new();
    private bool isSavingDetails;
    private string? detailsMessage;
    private bool detailsSuccess;

    private UpdateClubDescriptionRequest descriptionModel = new();
    private bool isSavingDescription;
    private string? descriptionMessage;
    private bool descriptionSuccess;

    private UpdateClubContactDetailsRequest contactModel = new();
    private bool isSavingContact;
    private string? contactMessage;
    private bool contactSuccess;

    private int? editingLocationId;
    private LocationEditModel locationEditModel = new();
    private bool isSavingLocation;
    private string? locationMessage;
    private bool locationSuccess;

    private AddClubLocationRequest addLocationModel = new();
    private bool isAddingLocation;
    private string? addLocationMessage;
    private bool addLocationSuccess;

    private int? editingMembershipLevelId;
    private RenameClubMembershipLevelRequest renameLevelModel = new();
    private bool isRenamingLevel;
    private string? levelMessage;
    private bool levelSuccess;

    private AddClubMembershipLevelRequest addLevelModel = new();
    private bool isAddingLevel;

    // Pilot policies
    private Guid? managingPolicyId;
    private List<PilotPolicyStatementResponse> policyStatements = [];
    private bool isPolicyStatementsLoading;
    private string selectedRequirementType = string.Empty;
    private bool isAddingRequirement;
    private string? requirementMessage;
    private bool requirementSuccess;
    private string? policyMessage;
    private bool policySuccess;

    private AddMinimumAgeRequirementRequest minAgeModel = new() { ValidationPolicy = "ANY" };
    private AddMaximumAgeRequirementRequest maxAgeModel = new() { ValidationPolicy = "ANY" };
    private AddInsuranceProviderRequirementRequest insuranceModel = new() { ValidationPolicy = "ANY" };
