@page "/club/create"
@attribute [Authorize]
@using NaeRaces.WebAPI.Shared.Club
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Create Club</PageTitle>

<h1>Create Club</h1>
<p class="text-muted">Enter the details for your new club. You will become the club administrator.</p>

<div class="row">
    <div class="col-md-6">
        <EditForm Model="request" OnValidSubmit="CreateAsync">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label for="code" class="form-label">Club Code <span class="text-danger">*</span></label>
                <InputText id="code" @bind-Value="request.Code" class="form-control" placeholder="e.g. NAER" />
                <div class="form-text">A short unique identifier for the club.</div>
            </div>

            <div class="mb-3">
                <label for="name" class="form-label">Club Name <span class="text-danger">*</span></label>
                <InputText id="name" @bind-Value="request.Name" class="form-control" placeholder="e.g. National Aerobatic Race Club" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    Create Club
                </button>
                <a href="/" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private readonly CreateClubRequest request = new();
    private bool isSubmitting;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        request.ClubId = Guid.NewGuid();
    }

    private async Task CreateAsync()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/club", request);

            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo($"/club/edit/{request.ClubId}");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                errorMessage = "A club with the same code or name already exists.";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                errorMessage = "Invalid request. Please check the club code and name.";
            }
            else
            {
                errorMessage = "Failed to create club. Please try again.";
            }
        }
        catch
        {
            errorMessage = "An error occurred. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
