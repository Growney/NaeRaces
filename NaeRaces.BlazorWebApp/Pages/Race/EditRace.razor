    private static async Task<string> GetErrorMessage(HttpResponseMessage response)
    {
        var body = await response.Content.ReadAsStringAsync();
        return string.IsNullOrWhiteSpace(body)
            ? $"Failed (HTTP {(int)response.StatusCode})."
            : body;
    }

