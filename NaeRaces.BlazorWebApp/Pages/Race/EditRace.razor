    private void ToggleEditPackage(int packageId)
    {
        if (editingPackageId == packageId)
        {
            editingPackageId = null;
            packageEditMessage = null;
            return;
        }

        editingPackageId = packageId;
        packageEditMessage = null;
        var pkg = packages.FirstOrDefault(p => p.RacePackageId == packageId);
        if (pkg != null)
        {
            editApplyDiscounts = pkg.ApplyDiscounts;
            editRegistrationOpen = pkg.RegistrationOpenDate ?? DateTime.UtcNow;
            editRegistrationClose = pkg.RegistrationCloseDate ?? DateTime.UtcNow;
            editPilotPolicyId = pkg.PilotPolicyId;
        }
    }

    private string GetPolicyName(Guid? policyId)
    {
        if (policyId == null) return "—";
        var policy = clubPolicies.FirstOrDefault(p => p.PolicyId == policyId.Value);
        return policy?.Name ?? "—";
    }

