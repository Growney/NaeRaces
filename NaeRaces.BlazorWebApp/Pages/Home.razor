@page "/"
@using NaeRaces.WebAPI.Shared.Club
@using NaeRaces.WebAPI.Shared.Race
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Home</PageTitle>

<!-- Races -->
<div class="card mb-3">
    <div class="card-header fw-bold">Races</div>
    <div class="card-body">
        @if (displayedRaces.Count == 0)
        {
            <p class="text-muted">No up coming races found.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Location</th>
                            <th>First Date</th>
                            <th>Registered</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var race in displayedRaces)
                        {
                            <tr style="cursor: pointer" @onclick="() => NavigateToRace(race.RaceId)">
                                <td>@race.Name</td>
                                <td>@(race.LocationName ?? "—")</td>
                                <td>@(race.FirstRaceDateStart != default ? race.FirstRaceDateStart.ToString("g") : "—")</td>
                                <td>
                                    @race.RegisteredPilotCount
                                    @if (race.MaximumPilots.HasValue)
                                    {
                                        <text> / @race.MaximumPilots</text>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (myClubs != null && myClubs.Length > 0)
{
    <div class="row mt-4">
        <div class="col-12">
            <h3>My Clubs</h3>
            <table class="table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Membership Level</th>
                        <th>Expiry</th>
                        <th>Roles</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var club in myClubs)
                    {
                        <tr style="cursor: pointer" @onclick="() => NavigateToClub(club.ClubId)">
                            <td>@club.ClubCode</td>
                            <td>@club.ClubName</td>
                            <td>@(club.IsFollowing ? "Following" : club.MembershipLevelName ?? "—")</td>
                            <td>@(club.IsFollowing ? "—" : club.MembershipExpiry?.ToString("d") ?? "—")</td>
                            <td>@(club.Roles.Count > 0 ? string.Join(", ", club.Roles) : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="row mt-4">
    <div class="col-12">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="Search clubs by name or code..."
                   value="@searchTerm"
                   @oninput="e => searchTerm = e.Value?.ToString() ?? string.Empty"
                   @onkeyup="HandleSearchKeyUpAsync" />
            <button class="btn btn-primary" @onclick="SearchAsync" disabled="@isSearching">
                @if (isSearching)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                }
                Search
            </button>
        </div>
    </div>
</div>

@if (searchResults != null)
{
    <div class="row mt-2">
        <div class="col-12">
            @if (searchResults.Count == 0)
            {
                <p>No clubs were found. <a href="/club/create">Create a new club</a>.</p>
            }
            else
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Members</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var club in searchResults)
                        {
                            <tr style="cursor: pointer" @onclick="() => NavigateToClub(club.ClubId)">
                                <td>@club.Code</td>
                                <td>@club.Name</td>
                                <td>@club.MemberCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

<div class="row mt-4">
    <div class="col-6">
        <h3>Top 10 Clubs by Members</h3>
        @if (topClubs == null)
        {
            <p><em>Loading...</em></p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Members</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var club in topClubs)
                    {
                        <tr style="cursor: pointer" @onclick="() => NavigateToClub(club.ClubId)">
                            <td>@club.Code</td>
                            <td>@club.Name</td>
                            <td>@club.MemberCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
    <div class="col-6">
        <h3>Clubs with Upcoming Races</h3>
        @if (clubsWithRaces == null)
        {
            <p><em>Loading...</em></p>
        }
        else if (!clubsWithRaces.Any())
        {
            <p>No clubs have upcoming races.</p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Members</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var club in clubsWithRaces)
                    {
                        <tr style="cursor: pointer" @onclick="() => NavigateToClub(club.ClubId)">
                            <td>@club.Code</td>
                            <td>@club.Name</td>
                            <td>@club.MemberCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private TopClubByMemberCountResponse[]? topClubs;
    private ClubWithUpcomingRacesResponse[]? clubsWithRaces;
    private MyClubMembershipResponse[]? myClubs;
    private string searchTerm = string.Empty;
    private List<ClubSearchResponse>? searchResults;
    private bool isSearching;
    private List<RaceInformationResponse> displayedRaces = [];

    private void NavigateToClub(Guid clubId)
    {
        Navigation.NavigateTo($"/club/{clubId}");
    }

    protected override async Task OnInitializedAsync()
    {
        var topClubsTask = Http.GetFromJsonAsync<TopClubByMemberCountResponse[]>("api/club/query/top/10");
        var clubsWithRacesTask = Http.GetFromJsonAsync<ClubWithUpcomingRacesResponse[]>("api/club/query/with-upcoming-races");
        var racesTask = Http.GetFromJsonAsync<List<RaceInformationResponse>>($"api/race/query/relevant");

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        Task<MyClubMembershipResponse[]?>? myClubsTask = null;
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            myClubsTask = Http.GetFromJsonAsync<MyClubMembershipResponse[]>("api/club/query/my-clubs");
        }

        await Task.WhenAll(
            topClubsTask,
            clubsWithRacesTask,
            myClubsTask ?? Task.CompletedTask,
            racesTask);

        topClubs = topClubsTask.Result;
        clubsWithRaces = clubsWithRacesTask.Result;
        myClubs = myClubsTask?.Result;
        displayedRaces = racesTask.Result;
    }

    private async Task HandleSearchKeyUpAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchAsync();
        }
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            searchResults = null;
            return;
        }

        isSearching = true;
        searchResults = null;

        var results = await Http.GetFromJsonAsync<ClubSearchResponse[]>(
            $"api/club/query/search?term={Uri.EscapeDataString(searchTerm)}");

        searchResults = results?.ToList() ?? [];
        isSearching = false;
    }

    private void NavigateToRace(Guid raceId)
    {
        Navigation.NavigateTo($"/race/{raceId}");
    }
}
